generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id          String           @id @default(uuid())
  name        String
  users       User[]
  kitchens    Kitchen[]
  invitations    UserInvitation[]
  auditLogs      AuditLog[]
  menuCategories MenuCategory[]
  ingredients    Ingredient[]
  suppliers      Supplier[]
  warehouses     Warehouse[]
  purchaseOrders PurchaseOrder[]
  grns           GoodsReceivedNote[]
  invoices       Invoice[]
  payments       Payment[]
  expenses       Expense[]
  copilotSessions CopilotSession[]
  shifts         Shift[]
  attendances    Attendance[]
  leaveRequests  LeaveRequest[]
  tasks          Task[]
  notifications  Notification[]
  customers      Customer[]
  feedbacks      Feedback[]
  coupons        Coupon[]
  marketingCampaigns MarketingCampaign[]
  parent         Organization?    @relation("OrganizationHierarchy", fields: [parentId], references: [id])
  parentId       String?
  children       Organization[]   @relation("OrganizationHierarchy")
  
  automationRules AutomationRule[]
  apiKeys        ApiKey[]
  subscription   Subscription?
  branding       TenantBranding?
  
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  password       String
  role           String         @default("STAFF") // OWNER, ADMIN, MANAGER, STAFF
  organization   Organization   @relation(fields: [organizationId], references: [id])
  organizationId String
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]
  copilotSessions CopilotSession[]
  shifts         Shift[]
  attendances    Attendance[]
  leaveRequests  LeaveRequest[]
  tasks          Task[]
  notifications  Notification[]
  twoFactorSecret String?
  isTwoFactorEnabled Boolean    @default(false)
  deviceSessions DeviceSession[]
  
  preparedOrders Order[]          @relation("OrderPreparedBy")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model UserInvitation {
  id             String       @id @default(uuid())
  email          String
  role           String       @default("STAFF")
  token          String       @unique
  status         String       @default("PENDING") // PENDING, ACCEPTED, EXPIRED
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
}

model AuditLog {
  id             String       @id @default(uuid())
  action         String       // e.g., "CREATE_USER", "UPDATE_MENU"
  resource       String       // e.g., "User", "Order"
  resourceId     String?
  details        Json?        // Changed fields, request payload, etc.
  ipAddress      String?
  user           User?        @relation(fields: [userId], references: [id])
  userId         String?
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime     @default(now())
}

model Kitchen {
  id             String         @id @default(uuid())
  name           String
  address        String?
  organization   Organization   @relation(fields: [organizationId], references: [id])
  organizationId String
  brands         VirtualBrand[]
  orders         Order[]
  expenses       Expense[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  shifts         Shift[]
}

model VirtualBrand {
  id        String   @id @default(uuid())
  name      String
  kitchen   Kitchen  @relation(fields: [kitchenId], references: [id])
  kitchenId String
  orders    Order[]
  expenses  Expense[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  COOKING
  PACKING
  READY
  DELIVERED
  CANCELLED
  REJECTED
}

enum OrderSource {
  MANUAL
  SWIGGY
  ZOMATO
  UBEREATS
}

model Order {
  id             String       @id @default(uuid())
  externalId     String?      // From UberEats/DoorDash/Swiggy
  source         OrderSource  @default(MANUAL)
  status         OrderStatus  @default(PENDING)
  subtotal       Float        @default(0)
  taxAmount      Float        @default(0)
  total          Float
  metadata       Json?        // Raw aggregator payload
  kitchen        Kitchen      @relation(fields: [kitchenId], references: [id])
  kitchenId      String
  brand          VirtualBrand @relation(fields: [brandId], references: [id])
  brandId        String
  items          OrderItem[]
  
  customer       Customer?      @relation(fields: [customerId], references: [id])
  customerId     String?
  feedback       Feedback?
  
  preparedBy     User?          @relation("OrderPreparedBy", fields: [preparedById], references: [id])
  preparedById   String?
  prepTimeSeconds Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model OrderItem {
  id       String  @id @default(uuid())
  name     String
  quantity Int
  price    Float
  order    Order   @relation(fields: [orderId], references: [id])
  orderId  String
}

model MenuCategory {
  id             String       @id @default(uuid())
  name           String
  description    String?
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  items          MenuItem[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model MenuItem {
  id             String              @id @default(uuid())
  name           String
  description    String?
  basePrice      Float
  isCombo        Boolean             @default(false)
  category       MenuCategory        @relation(fields: [categoryId], references: [id])
  categoryId     String
  variants       MenuItemVariant[]
  modifierGroups MenuModifierGroup[]
  recipe         Recipe?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model MenuItemVariant {
  id          String    @id @default(uuid())
  name        String    // e.g., "Small", "Large"
  price       Float
  menuItem    MenuItem  @relation(fields: [menuItemId], references: [id])
  menuItemId  String
  recipe      Recipe?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model MenuModifierGroup {
  id          String         @id @default(uuid())
  name        String         // e.g., "Add-ons", "Crust Type"
  isRequired  Boolean        @default(false)
  maxSelect   Int?
  menuItem    MenuItem       @relation(fields: [menuItemId], references: [id])
  menuItemId  String
  modifiers   MenuModifier[]
}

model MenuModifier {
  id               String            @id @default(uuid())
  name             String
  price            Float             @default(0)
  modifierGroup    MenuModifierGroup @relation(fields: [modifierGroupId], references: [id])
  modifierGroupId  String
}

model Ingredient {
  id             String             @id @default(uuid())
  name           String
  unit           String             // e.g., "kg", "g", "ml", "unit"
  unitCost       Float              // Cost per unit
  organization   Organization       @relation(fields: [organizationId], references: [id])
  organizationId String
  reorderPoint   Float              @default(0)
  recipes        RecipeIngredient[]
  batches        InventoryBatch[]
  transactions   InventoryTransaction[]
  poItems        PurchaseOrderItem[]
  grnItems       GrnItem[]
  priceHistory   PriceHistory[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model Recipe {
  id               String             @id @default(uuid())
  prepTimeMinutes  Int
  calories         Int?
  version          Int                @default(1)
  menuItem         MenuItem?          @relation(fields: [menuItemId], references: [id])
  menuItemId       String?            @unique
  variant          MenuItemVariant?   @relation(fields: [variantId], references: [id])
  variantId        String?            @unique
  ingredients      RecipeIngredient[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model RecipeIngredient {
  id           String     @id @default(uuid())
  quantity     Float
  recipe       Recipe     @relation(fields: [recipeId], references: [id])
  recipeId     String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  ingredientId String
}

model Supplier {
  id             String         @id @default(uuid())
  name           String
  contactName    String?
  email          String?
  phone          String?
  rating         Float          @default(5.0)
  paymentTerms   String?
  organization   Organization   @relation(fields: [organizationId], references: [id])
  organizationId String
  batches        InventoryBatch[]
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]
  priceHistory   PriceHistory[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Warehouse {
  id             String         @id @default(uuid())
  name           String
  location       String?
  organization   Organization   @relation(fields: [organizationId], references: [id])
  organizationId String
  batches        InventoryBatch[]
  transactions   InventoryTransaction[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model InventoryBatch {
  id             String         @id @default(uuid())
  batchNumber    String
  quantity       Float
  unitCost       Float
  expiryDate     DateTime?
  receivedAt     DateTime       @default(now())
  
  ingredient     Ingredient     @relation(fields: [ingredientId], references: [id])
  ingredientId   String
  supplier       Supplier?      @relation(fields: [supplierId], references: [id])
  supplierId     String?
  warehouse      Warehouse      @relation(fields: [warehouseId], references: [id])
  warehouseId    String
  
  transactions   InventoryTransaction[]
  
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

enum TransactionType {
  IN
  OUT
  TRANSFER
  WASTE
  ADJUSTMENT
}

model InventoryTransaction {
  id             String          @id @default(uuid())
  type           TransactionType
  quantity       Float           // Positive for IN, Negative for OUT/WASTE
  reference      String?         // e.g., Order ID, PO ID, or reason
  
  ingredient     Ingredient      @relation(fields: [ingredientId], references: [id])
  ingredientId   String
  batch          InventoryBatch? @relation(fields: [batchId], references: [id])
  batchId        String?
  warehouse      Warehouse       @relation(fields: [warehouseId], references: [id])
  warehouseId    String
  
  createdAt      DateTime        @default(now())
}

enum PurchaseOrderStatus {
  DRAFT
  ISSUED
  PARTIAL_RECEIPT
  FULFILLED
  CANCELLED
}

model PurchaseOrder {
  id             String                @id @default(uuid())
  status         PurchaseOrderStatus   @default(DRAFT)
  totalAmount    Float                 @default(0)
  expectedDate   DateTime?
  
  organization   Organization          @relation(fields: [organizationId], references: [id])
  organizationId String
  supplier       Supplier              @relation(fields: [supplierId], references: [id])
  supplierId     String
  
  items          PurchaseOrderItem[]
  grns           GoodsReceivedNote[]
  
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

model PurchaseOrderItem {
  id               String          @id @default(uuid())
  quantityOrdered  Float
  quantityReceived Float           @default(0)
  unitCost         Float
  
  purchaseOrder    PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId  String
  ingredient       Ingredient      @relation(fields: [ingredientId], references: [id])
  ingredientId     String
}

model GoodsReceivedNote {
  id               String          @id @default(uuid())
  receivedDate     DateTime        @default(now())
  notes            String?
  
  purchaseOrder    PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId  String
  organization     Organization    @relation(fields: [organizationId], references: [id])
  organizationId   String
  
  items            GrnItem[]
  invoice          Invoice?
  
  createdAt        DateTime        @default(now())
}

model GrnItem {
  id               String            @id @default(uuid())
  quantityReceived Float
  quantityDamaged  Float             @default(0)
  
  grn              GoodsReceivedNote @relation(fields: [grnId], references: [id])
  grnId            String
  ingredient       Ingredient        @relation(fields: [ingredientId], references: [id])
  ingredientId     String
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
}

model Invoice {
  id               String            @id @default(uuid())
  invoiceNumber    String
  amountDue        Float
  amountPaid       Float             @default(0)
  dueDate          DateTime?
  status           InvoiceStatus     @default(UNPAID)
  
  supplier         Supplier          @relation(fields: [supplierId], references: [id])
  supplierId       String
  grn              GoodsReceivedNote @relation(fields: [grnId], references: [id])
  grnId            String            @unique
  organization     Organization      @relation(fields: [organizationId], references: [id])
  organizationId   String
  
  payments         Payment[]
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Payment {
  id               String            @id @default(uuid())
  amount           Float
  date             DateTime          @default(now())
  method           String            
  
  invoice          Invoice           @relation(fields: [invoiceId], references: [id])
  invoiceId        String
  organization     Organization      @relation(fields: [organizationId], references: [id])
  organizationId   String
}

model PriceHistory {
  id               String            @id @default(uuid())
  unitCost         Float
  date             DateTime          @default(now())
  
  ingredient       Ingredient        @relation(fields: [ingredientId], references: [id])
  ingredientId     String
  supplier         Supplier          @relation(fields: [supplierId], references: [id])
  supplierId       String
}

enum ExpenseCategory {
  LABOR
  RENT
  UTILITIES
  MARKETING
  MAINTENANCE
  OTHER
}

model Expense {
  id             String          @id @default(uuid())
  amount         Float
  category       ExpenseCategory
  description    String?
  date           DateTime        @default(now())
  
  organization   Organization    @relation(fields: [organizationId], references: [id])
  organizationId String
  kitchen        Kitchen?        @relation(fields: [kitchenId], references: [id])
  kitchenId      String?
  brand          VirtualBrand?   @relation(fields: [brandId], references: [id])
  brandId        String?
  
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model CopilotSession {
  id             String          @id @default(uuid())
  title          String?
  organization   Organization    @relation(fields: [organizationId], references: [id])
  organizationId String
  user           User            @relation(fields: [userId], references: [id])
  userId         String
  messages       CopilotMessage[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum CopilotRole {
  USER
  AI
  SYSTEM
}

model CopilotMessage {
  id             String          @id @default(uuid())
  role           CopilotRole
  content        String
  session        CopilotSession  @relation(fields: [sessionId], references: [id])
  sessionId      String
  createdAt      DateTime        @default(now())
}

model Shift {
  id             String       @id @default(uuid())
  startTime      DateTime
  endTime        DateTime
  role           String
  
  user           User         @relation(fields: [userId], references: [id])
  userId         String
  kitchen        Kitchen      @relation(fields: [kitchenId], references: [id])
  kitchenId      String
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Attendance {
  id             String       @id @default(uuid())
  clockIn        DateTime
  clockOut       DateTime?
  totalHours     Float?
  
  user           User         @relation(fields: [userId], references: [id])
  userId         String
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  
  createdAt      DateTime     @default(now())
}

model LeaveRequest {
  id             String       @id @default(uuid())
  startDate      DateTime
  endDate        DateTime
  reason         String?
  status         String       @default("PENDING") 
  
  user           User         @relation(fields: [userId], references: [id])
  userId         String
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Task {
  id             String       @id @default(uuid())
  description    String
  isCompleted    Boolean      @default(false)
  dueDate        DateTime?
  
  user           User         @relation(fields: [userId], references: [id])
  userId         String
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Customer {
  id             String       @id @default(uuid())
  name           String
  phone          String
  email          String?
  lifetimeValue  Float        @default(0.0)
  loyaltyPoints  Int          @default(0)
  walletBalance  Float        @default(0.0)
  segment        String       @default("NEW") 
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  
  orders         Order[]
  feedbacks      Feedback[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Feedback {
  id             String       @id @default(uuid())
  rating         Int          
  review         String?
  
  order          Order        @relation(fields: [orderId], references: [id])
  orderId        String       @unique
  
  customer       Customer     @relation(fields: [customerId], references: [id])
  customerId     String
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  
  createdAt      DateTime     @default(now())
}

model Coupon {
  id             String       @id @default(uuid())
  code           String       @unique
  discountType   String       
  discountAmount Float
  expiryDate     DateTime?
  isActive       Boolean      @default(true)
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  
  marketingCampaign   MarketingCampaign? @relation(fields: [marketingCampaignId], references: [id])
  marketingCampaignId String?
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum NotificationType {
  INVENTORY
  ORDER
  HR
  FINANCE
  SYSTEM
}

model Notification {
  id             String           @id @default(uuid())
  type           NotificationType
  title          String
  message        String
  isRead         Boolean          @default(false)
  channels       String[]         
  
  user           User?            @relation(fields: [userId], references: [id])
  userId         String?
  organization   Organization     @relation(fields: [organizationId], references: [id])
  organizationId String
  
  createdAt      DateTime         @default(now())
}

model MarketingCampaign {
  id             String       @id @default(uuid())
  name           String
  targetSegment  String       
  channels       String[]     
  status         String       @default("DRAFT") 
  
  sentCount      Int          @default(0)
  openCount      Int          @default(0)
  conversionCount Int         @default(0)
  revenueGenerated Float      @default(0.0)

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  
  coupons        Coupon[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model AutomationRule {
  id             String       @id @default(uuid())
  name           String
  trigger        String       // e.g., INVENTORY_LOW, ORDER_DELAYED
  conditionJson  String       // JSON logic
  actionJson     String       // JSON logic
  isActive       Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ApiKey {
  id             String       @id @default(uuid())
  name           String
  keyHash        String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  createdAt      DateTime     @default(now())
  lastUsedAt     DateTime?
}

model Subscription {
  id             String       @id @default(uuid())
  plan           String       @default("STARTER") // STARTER, PRO, ENTERPRISE
  status         String       @default("ACTIVE")  // ACTIVE, PAST_DUE, CANCELED
  stripeCustId   String?
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model TenantBranding {
  id             String       @id @default(uuid())
  primaryColor   String       @default("#4F46E5")
  logoUrl        String?
  customDomain   String?      @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model DeviceSession {
  id             String       @id @default(uuid())
  userAgent      String
  ipAddress      String
  isActive       Boolean      @default(true)
  user           User         @relation(fields: [userId], references: [id])
  userId         String
  createdAt      DateTime     @default(now())
  lastSeenAt     DateTime     @default(now())
}
